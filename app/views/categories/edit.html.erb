<div class="mx-auto md:w-2/3 w-full">
  <h1 class="font-bold text-4xl">Editing category</h1>

  <%= render "form", category: @category %>

  <%= button_to "Remove this category", category_path(@category), method: :delete, class: "btn-grey", form: { data: { turbo_confirm: "Are you sure?" } } %>
  <%= link_to "Back to agenda", categories_path, class: "ml-2 rounded-lg py-3 px-5 bg-gray-100 inline-block font-medium" %>
</div>
